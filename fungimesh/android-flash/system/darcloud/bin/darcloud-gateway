.tier-card{padding:12px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);font-size:12px}
.tier-card.free{border-color:#4caf50} .tier-card.pro{border-color:#3a7bd5}
.status{margin-top:16px;padding:8px;border-radius:8px;background:rgba(76,175,80,0.1);border:1px solid rgba(76,175,80,0.3);font-size:12px;color:#4caf50}
</style>
</head>
<body>
<div class="card">
