# --- Captive portal HTTP server ---
start_captive_portal() {
    log "Starting captive portal on port $CAPTIVE_PORTAL_PORT..."

    PORTAL_HTML=$(cat "$PORTAL_DIR/index.html" 2>/dev/null)

    while true; do
        # Read HTTP request
        REQUEST=$(toybox nc -l -p "$CAPTIVE_PORTAL_PORT" -w 10 2>/dev/null < /dev/null &
        sleep 0.1

        # Check if it's a connect API call or page request
        if echo "$REQUEST" | grep -q "POST /api/connect"; then
            RESPONSE='{"status":"connected","tier":"free","daily_limit_mb":50}'
            echo -e "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: ${#RESPONSE}\r\nAccess-Control-Allow-Origin: *\r\n\r\n$RESPONSE"
        elif echo "$REQUEST" | grep -q "generate_204\|hotspot-detect\|captive"; then
            # Android/iOS captive portal detection — redirect
            echo -e "HTTP/1.1 302 Found\r\nLocation: http://10.78.0.1:$CAPTIVE_PORTAL_PORT/\r\n\r\n"
        else
            echo -e "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\nContent-Length: ${#PORTAL_HTML}\r\n\r\n$PORTAL_HTML"
        fi) | toybox nc -l -p "$CAPTIVE_PORTAL_PORT" -w 10 2>/dev/null
    done &

    PORTAL_PID=$!
    echo "$PORTAL_PID" > "$PID_DIR/captive-portal.pid"
    log "Captive portal running (PID: $PORTAL_PID)"
}

# --- Client tracking ---
track_clients() {
    AP_IFACE=$(cat "$DATA_DIR/ap-interface" 2>/dev/null || echo "wlan1")

    CLIENTS=$(ip neigh show dev "$AP_IFACE" 2>/dev/null | grep REACHABLE | wc -l)
    log "Connected clients: $CLIENTS"

    # Log to file
    ip neigh show dev "$AP_IFACE" 2>/dev/null > "$DATA_DIR/connected-clients.txt"
}

# --- Main ---
detect_wifi_hardware
setup_hostapd
setup_dhcp
setup_nat
generate_captive_portal
start_captive_portal

# Monitor loop
while true; do
    track_clients
    sleep 60
done
