#!/system/bin/sh
##############################################################################
# DarCloud WiFi Gateway — Bare Metal Access Point + Captive Portal
# Turns Samsung phone into WiFi hotspot with DarCloud captive portal
# Uses Android's hostapd or tethering infrastructure
##############################################################################

. /system/darcloud/etc/darcloud.conf

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') [GATEWAY] $1" >> "$LOG_DIR/gateway.log"; }

log "Bismillah — WiFi Gateway starting on bare metal..."
echo $$ > "$PID_DIR/gateway.pid"

PORTAL_DIR="$DATA_DIR/captive-portal"
mkdir -p "$PORTAL_DIR"

# --- Detect WiFi chipset and interfaces ---
detect_wifi_hardware() {
    log "Detecting WiFi hardware..."

    # Samsung phones typically have wlan0 (client) and can create wlan1 (AP) or use softap0
    WIFI_CHIPSET=$(getprop wifi.interface 2>/dev/null || echo "wlan0")
    AP_IFACE=""

    # Check for existing AP interface
    for iface in softap0 wlan1 ap0 swlan0; do
        if [ -e "/sys/class/net/$iface" ]; then
            AP_IFACE="$iface"
            break
        fi
    done

    # If no AP interface, try to create one
    if [ -z "$AP_IFACE" ]; then
        iw dev "$WIFI_CHIPSET" interface add wlan1 type __ap 2>/dev/null
        if [ -e "/sys/class/net/wlan1" ]; then
            AP_IFACE="wlan1"
        fi
    fi

    if [ -n "$AP_IFACE" ]; then
        log "AP interface: $AP_IFACE (chipset: $WIFI_CHIPSET)"
    else
        log "WARNING: No AP interface available — using Android tethering API"
        AP_IFACE="softap0"
        # Enable tethering via Android settings command
        svc wifi enable 2>/dev/null
        cmd connectivity tethering wifi enable 2>/dev/null
        settings put global tether_offload_disabled 0 2>/dev/null
        sleep 3
    fi

    echo "$AP_IFACE" > "$DATA_DIR/ap-interface"
}

# --- Configure hostapd (if available) ---
setup_hostapd() {
    AP_IFACE=$(cat "$DATA_DIR/ap-interface" 2>/dev/null || echo "wlan1")

    cat > "$DATA_DIR/hostapd.conf" << HOSTAPD
interface=$AP_IFACE
driver=nl80211
ssid=$WIFI_SSID
hw_mode=g
channel=$WIFI_CHANNEL
wmm_enabled=0
macaddr_acl=0
auth_algs=1
ignore_broadcast_ssid=0
wpa=2
wpa_passphrase=$WIFI_PASS
wpa_key_mgmt=WPA-PSK
wpa_pairwise=TKIP
rsn_pairwise=CCMP
HOSTAPD

    # Try system hostapd first, then our bundled one
    if command -v hostapd > /dev/null 2>&1; then
        hostapd -B "$DATA_DIR/hostapd.conf" 2>/dev/null
        log "hostapd started on $AP_IFACE (SSID: $WIFI_SSID)"
    elif [ -f /system/bin/hostapd ]; then
        /system/bin/hostapd -B "$DATA_DIR/hostapd.conf" 2>/dev/null
        log "System hostapd started"
    else
        log "hostapd not available — relying on Android WiFi tethering"
        # Use Android's built-in tethering with our SSID
        cmd wifi set-softap-config "$WIFI_SSID" wpa2 "$WIFI_PASS" 2>/dev/null
        cmd wifi start-softap 2>/dev/null
    fi
}

# --- DHCP server ---
setup_dhcp() {
    AP_IFACE=$(cat "$DATA_DIR/ap-interface" 2>/dev/null || echo "wlan1")

    # Assign IP to AP interface
    ip addr flush dev "$AP_IFACE" 2>/dev/null
    ip addr add 10.78.0.1/24 dev "$AP_IFACE" 2>/dev/null
    ip link set "$AP_IFACE" up 2>/dev/null

    # Use dnsmasq if available
    if command -v dnsmasq > /dev/null 2>&1; then
        cat > "$DATA_DIR/dnsmasq.conf" << DNSMASQ
interface=$AP_IFACE
dhcp-range=$DHCP_RANGE_START,$DHCP_RANGE_END,$DHCP_LEASE
dhcp-option=option:router,10.78.0.1
dhcp-option=option:dns-server,1.1.1.1,8.8.8.8
server=1.1.1.1
server=8.8.8.8
log-queries
log-dhcp
log-facility=$LOG_DIR/dnsmasq.log
address=/captive.darcloud.host/10.78.0.1
address=/connectivitycheck.gstatic.com/10.78.0.1
address=/captive.apple.com/10.78.0.1
DNSMASQ
        dnsmasq -C "$DATA_DIR/dnsmasq.conf" 2>/dev/null
        log "dnsmasq DHCP started ($DHCP_RANGE_START - $DHCP_RANGE_END)"
    else
        log "dnsmasq not available — Android handles DHCP via tethering"
    fi
}

# --- NAT / IP forwarding ---
setup_nat() {
    AP_IFACE=$(cat "$DATA_DIR/ap-interface" 2>/dev/null || echo "wlan1")

    echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null

    # Detect upstream interface (mobile data or wifi client)
    UPSTREAM=""
    for iface in rmnet_data0 rmnet0 ccmni0 wlan0; do
        if ip link show "$iface" 2>/dev/null | grep -q UP; then
            UPSTREAM="$iface"
            break
        fi
    done

    if [ -n "$UPSTREAM" ]; then
        # NAT using iptables
        iptables -t nat -A POSTROUTING -o "$UPSTREAM" -j MASQUERADE 2>/dev/null
        iptables -A FORWARD -i "$AP_IFACE" -o "$UPSTREAM" -j ACCEPT 2>/dev/null
        iptables -A FORWARD -i "$UPSTREAM" -o "$AP_IFACE" -m state --state ESTABLISHED,RELATED -j ACCEPT 2>/dev/null

        # Redirect captive portal detection to our portal
        iptables -t nat -A PREROUTING -i "$AP_IFACE" -p tcp --dport 80 \
            -d connectivitycheck.gstatic.com -j DNAT --to-destination 10.78.0.1:$CAPTIVE_PORTAL_PORT 2>/dev/null
        iptables -t nat -A PREROUTING -i "$AP_IFACE" -p tcp --dport 80 \
            -d captive.apple.com -j DNAT --to-destination 10.78.0.1:$CAPTIVE_PORTAL_PORT 2>/dev/null

        log "NAT configured: $AP_IFACE -> $UPSTREAM"
    else
        log "WARNING: No upstream interface found"
    fi
}

# --- Captive Portal HTML ---
generate_captive_portal() {
    cat > "$PORTAL_DIR/index.html" << 'PORTAL'
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>DarCloud WiFi — Bismillah</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:linear-gradient(135deg,#0a0a0a 0%,#1a1a2e 50%,#16213e 100%);min-height:100vh;display:flex;justify-content:center;align-items:center;color:#fff}
.card{background:rgba(255,255,255,0.05);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.1);border-radius:24px;padding:40px;max-width:420px;width:90%;text-align:center}
