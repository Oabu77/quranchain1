# DarCloud WiFi Gateway — Android init service
# WiFi AP + captive portal + DHCP on bare hardware

service darcloud_gateway /system/darcloud/bin/darcloud-gateway
    class late_start
    user root
    group root inet net_admin net_raw wifi
    disabled
    oneshot
    seclabel u:r:shell:s0
    writepid /dev/cpuset/system-background/tasks

on property:darcloud.gateway.start=1
    start darcloud_gateway
