# Omar AI™ AMĀN Control Plane — Android Init Service
# Auto-starts Omar AI sovereign agent on boot
# Depends on: meshnode, 5g-modem (waits for network)

service darcloud_omarai /system/darcloud/bin/darcloud-omarai
    class late_start
    user root
    group root net_admin net_raw inet
    disabled
    oneshot
    seclabel u:r:su:s0

on property:sys.boot_completed=1
    start darcloud_omarai
